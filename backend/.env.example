# 本地开发可复制为 .env，Docker/部署环境优先使用真实环境变量注入。

# 应用基础配置
APP_NAME=OfferPilot API
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# Web 服务运行配置
APP_HOST=0.0.0.0
APP_PORT=8000

# 数据库与缓存配置
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/offercopilot

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# 鉴权配置
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI 与对象存储预留配置
OPENAI_API_KEY=
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=
